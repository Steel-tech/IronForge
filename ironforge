#!/bin/bash

# IronForge - AI-Powered Ironworker Business Wizard
# Startup script

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

PORT=3000

# ─── Colors ────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color

# ─── Functions ─────────────────────────────────────────────────────────
check_dependency() {
  if ! command -v "$1" &> /dev/null; then
    echo -e "${RED}✗ $1 is not installed${NC}"
    return 1
  fi
  echo -e "${GREEN}✓${NC} $1 $(command -v "$1" | head -1)"
  return 0
}

kill_port() {
  local pid
  pid=$(lsof -ti tcp:"$PORT" 2>/dev/null || true)
  if [ -n "$pid" ]; then
    echo -e "${YELLOW}⚠ Port $PORT in use (PID: $pid) — killing...${NC}"
    kill -9 $pid 2>/dev/null || true
    sleep 1
    echo -e "${GREEN}✓${NC} Port $PORT cleared"
  fi
}

check_env() {
  if [ ! -f ".env.local" ]; then
    if [ -f ".env.example" ]; then
      echo -e "${YELLOW}⚠ No .env.local found. Copy .env.example and add your API key:${NC}"
      echo -e "  ${DIM}cp .env.example .env.local${NC}"
      echo ""
    else
      echo -e "${YELLOW}⚠ No .env.local found. Create one with:${NC}"
      echo -e "  ${DIM}echo 'ANTHROPIC_API_KEY=your-key-here' > .env.local${NC}"
      echo ""
    fi
  else
    if grep -q "ANTHROPIC_API_KEY" .env.local 2>/dev/null; then
      echo -e "${GREEN}✓${NC} ANTHROPIC_API_KEY configured"
    else
      echo -e "${YELLOW}⚠ ANTHROPIC_API_KEY not found in .env.local${NC}"
    fi
  fi
}

install_deps() {
  if [ ! -d "node_modules" ]; then
    echo -e "${CYAN}📦 Installing dependencies...${NC}"
    npm install
    echo ""
  fi
}

# ─── Startup ───────────────────────────────────────────────────────────
clear

echo -e "${CYAN}"
cat << 'BANNER'

  🔥 Starting IronForge...

BANNER
echo -e "${NC}"

# Preflight checks
echo -e "${BOLD}Preflight Checks${NC}"
echo -e "${DIM}────────────────────────────────────────${NC}"
check_dependency "node"
check_dependency "npm"
check_env
echo ""

# Kill existing port
kill_port

# Install deps if needed
install_deps

# Banner
echo -e "${CYAN}${BOLD}"
cat << 'BANNER'

  ██╗██████╗  ██████╗ ███╗   ██╗███████╗ ██████╗ ██████╗  ██████╗ ███████╗
  ██║██╔══██╗██╔═══██╗████╗  ██║██╔════╝██╔═══██╗██╔══██╗██╔════╝ ██╔════╝
  ██║██████╔╝██║   ██║██╔██╗ ██║█████╗  ██║   ██║██████╔╝██║  ███╗█████╗
  ██║██╔══██╗██║   ██║██║╚██╗██║██╔══╝  ██║   ██║██╔══██╗██║   ██║██╔══╝
  ██║██║  ██║╚██████╔╝██║ ╚████║██║     ╚██████╔╝██║  ██║╚██████╔╝███████╗
  ╚═╝╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═══╝╚═╝      ╚═════╝ ╚═╝  ╚═╝ ╚═════╝ ╚══════╝

BANNER
echo -e "${NC}"

echo -e "  ${BOLD}AI-Powered Ironworker Business Wizard${NC}"
echo -e "  ${DIM}All 50 States — Licensing, Bonding, Insurance & Union Signatory${NC}"
echo ""
echo -e "  👉 Open here: ${BOLD}${GREEN}http://localhost:${PORT}${NC}"
echo ""
echo -e "  ${DIM}═══════════════════════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  ${DIM}All logs will show below this:${NC}"
echo ""

# Launch Next.js dev server
exec npx next dev --turbopack --port "$PORT"
